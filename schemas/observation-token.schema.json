{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://looping.dev/schemas/observation-token.schema.json",
  "title": "ObservationToken",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "name", "value", "source", "confidence"],
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["dom", "screen", "file", "sensor", "api", "human"]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "value": {},
    "source": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
